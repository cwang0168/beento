DATABASE_URL="postgresql://beento:beento@localhost:5433/beento"
JWT_SECRET="dev-secret-change-me"
PORT=3000

# Shared secret Cloud Scheduler sends as the x-cron-secret header when
# triggering POST /recommendations/refresh and POST /trips/:id/prompt/notify.
CRON_SECRET="dev-cron-secret-change-me"

# Optional. Leave unset locally -- Sentry/Google Places integrations are
# inert without these.
SENTRY_DSN=
GOOGLE_PLACES_API_KEY=
